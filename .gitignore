# Python/runtime caches
__pycache__/
*.py[cod]
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage

# Archived migration material
legacy_unused/

# Local datasets and generated ledgers
data/**/*.parquet
data/**/*.csv
!data/**/.gitkeep

# Model binaries, checkpoints, and generated model outputs
models/**/weights.bin
models/**/*.pt
models/**/*.pth
models/**/*.pkl
models/**/*.joblib
models/dev/var_*/*
!models/dev/var_*/.gitkeep
!models/prod/model_slot_*/.gitkeep

# Reference-counted scaler binaries
scalers/**/*.pkl
!scalers/**/.gitkeep

# Local automation runtime state
automation/*.ps1
automation/optimization/*.db
automation/optimization/*.sqlite
automation/optimization/*.sqlite3
automation/optimization/*_top5.yaml
automation/optimization/*_family_selection.yaml
automation/optimization/search_config.yaml
automation/optimization/*.example
automation/run_requests/*.yaml
automation/run_requests/*.yml
automation/run_requests/*.example
automation/runs_done/*.yaml
automation/runs_done/*.yml
automation/delete_requests/*.yaml
automation/delete_requests/*.yml
automation/deleted_runs/*.yaml
automation/deleted_runs/*.yml
automation/rejected_runs/*.yaml
automation/rejected_runs/*.yml
!automation/**/.gitkeep
!automation/**/*.example
automation/optimization/*.example
automation/run_requests/*.example
!automation/config.yaml

# Local logs
*.log
