model_type: ensemble
variation_id: 1
train_mode: static_baseline
model_id: replace_with_model_id
hyperparameters:
  seed: 42
  train_length: 100000
  test_length: 5000
  confidence_threshold: 0.5
  min_member_probability: 0.0
  models_pool:
    - replace_with_member_model_id
  voting_mechanism: hard_majority
  tie_breaker: soft_average
