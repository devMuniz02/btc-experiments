model_type: lstm # lstm | transformer | mamba | nn | logistic_regression | rf | xgboost | bc | dagger | ppo | actor_critic
variation_id: 1 # >= 1; canonical var_1 = 1
train_mode: static_baseline # static_baseline | sliding_window_current_only | sliding_window_continue | sliding_window_retrain | post_base
model_id: replace_with_model_id # existing completed model id for delete requests
hyperparameters:
  seed: 42 # >= 0 integer
  train_length: 100000 # >= 1 integer; canonical 100000
  test_length: 5000 # >= 1 integer; canonical 5000
  sequence_length: 24 # >= 1 integer; legacy default 24
  action_dim: 2 # 2 for binary sell/buy; 0=sell, 1=buy
  hidden_dim: 128 # >= 1 integer
  num_layers: 2 # >= 1 integer
  epochs: 20 # >= 1 integer
  batch_size: 64 # >= 1 integer; lower on CUDA OOM
  eval_batch_size: 1024 # >= 1 integer
  learning_rate: 0.001 # > 0 float
  weight_decay: 0.0 # >= 0 float
  dropout: 0.1 # [0.0, 1.0] float
  gradient_clip_norm: 0.0 # >= 0 float; 0 disables
  early_stopping_patience: 0 # >= 0 integer; 0 disables
  validation_fraction: 0.0 # [0.0, 1.0) float; 0 disables
  device: auto # auto | cuda | cpu
  preload_to_device: false # true | false

