model_type: dagger
variation_id: 1
train_mode: static_baseline
force_run: false
hyperparameters:
  seed: 42
  train_length: 100000
  test_length: 5000
  sequence_length: 24
  hidden_dim: 256
  action_dim: 2
  reward_value: 1.0
  rounds: 4
  fit_epochs_per_round: 2
  batch_size: 64
  eval_batch_size: 1024
  learning_rate: 0.001
  expert_mix_start: 1.0
  expert_mix_end: 0.0
  aggregation_fraction: 1.0
  weight_decay: 0.0
  dropout: 0.1
  device: auto
  preload_to_device: false
